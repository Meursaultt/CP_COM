            "formatString": "#,0.00 \"€\";-#,0.00 \"€\";#,0.00 \"€\"",
            "sourceProviderType": "Currency",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1036\" DisplayName=\"€ Français (France)\" Symbol=\"€\" PositivePattern=\"3\" NegativePattern=\"8\" /></Format>"
              }
            ]
          },
          {
            "name": "TOTAL_INVENDU_POINTE",
            "dataType": "int64",
            "sourceColumn": "TOTAL_INVENDU_POINTE",
            "sourceProviderType": "Integer"
          },
          {
            "name": "TOTAL_RENDUS_COM",
            "dataType": "int64",
            "sourceColumn": "TOTAL_RENDUS_COM",
            "sourceProviderType": "Integer"
          },
          {
            "name": "TOTAL_RENDUS_US",
            "dataType": "int64",
            "sourceColumn": "TOTAL_RENDUS_US",
            "sourceProviderType": "Integer"
          },
          {
            "type": "calculated",
            "name": "Prix Global",
            "dataType": "decimal",
            "isDataTypeInferred": true,
            "expression": " ([TOTAL_CHARGEE] * [PRIX_VNT]) ",
            "formatString": "#,0.00 \"€\";-#,0.00 \"€\";#,0.00 \"€\"",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1036\" DisplayName=\"€ Français (France)\" Symbol=\"€\" PositivePattern=\"3\" NegativePattern=\"8\" /></Format>"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "FACT_SALES",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " SELECT [dbo].[FACT_SALES].* FROM [dbo].[FACT_SALES] ",
              "dataSource": "SqlServer MEURSAULTDW data_warehouse"
            }
          }
        ],
        "measures": [
          {
            "name": "Prix Total",
            "expression": [
              " SUMX( FACT_SALES , FACT_SALES[PRIX_VNT]*FACT_SALES[QTY TOTAL])",
              ""
            ]
          },
          {
            "name": "QTY TOTAL",
            "expression": " SUM(FACT_SALES[TOTAL_CHARGEE])"
          },
          {
            "name": "POIDS TOTAL",
            "expression": [
              "",
              "SUMX(",
              "    FACT_SALES,",
              "    FACT_SALES[TOTAL_CHARGEE] * RELATED(DIM_ARTICLE[Poids])/1000000",
              ")"
            ]
          },
          {
            "name": "Perte en Kg",
            "expression": [
              "",
              "SUMX(",
              "    FACT_SALES,",
              "    (FACT_SALES[TOTAL_RENDUS_US] + FACT_SALES[TOTAL_RENDUS_COM]) * (RELATED(DIM_ARTICLE[Poids]) / 1000000)",
              ")"
            ]
          },
          {
            "name": "Perte en DH",
            "expression": [
              "",
              "SUMX(",
              "    FACT_SALES,",
              "    (FACT_SALES[TOTAL_RENDUS_US] + FACT_SALES[TOTAL_RENDUS_COM]) * FACT_SALES[PRIX_VNT]",
              ")"
            ]
          },
          {
            "name": "POIDS INVENDU TOTAL",
            "expression": [
              "",
              "SUMX(",
              "    FACT_SALES,",
              "    FACT_SALES[TOTAL_INVENDU_POINTE] * RELATED(DIM_ARTICLE[Poids])/1000000",
              ")"
            ]
          },
          {
            "name": "Poids Venduuu Growth %",
            "expression": [
              "",
              "VAR PoidsActuel = [POIDS TOTAL]",
              "VAR PoidsPrecedent =",
              "    CALCULATE(",
              "        [POIDS TOTAL],",
              "        DATEADD(DIM_DATE[Mois_Fiscal], -1, MONTH)",
              "    )",
              "RETURN DIVIDE(PoidsActuel - PoidsPrecedent, PoidsPrecedent,0)"
            ]
          },
          {
            "name": "Poids Venduu Growth %",
            "expression": [
              "",
              "VAR PoidsActuel = [POIDS TOTAL]",
              "VAR PoidsPrecedent =",
              "    CALCULATE(",
              "        [POIDS TOTAL],",
              "        DATEADD(DIM_DATE[Mois_Fiscal], -1, MONTH)",
              "    )",
              "RETURN",
              "    DIVIDE(PoidsActuel - PoidsPrecedent, PoidsPrecedent, 0)"
            ],
            "formatString": "0.00 %;-0.00 %;0.00 %"
          },
          {
            "name": "Montant Venduu Growth%",
            "expression": [
              "",
              "VAR PoidsActuel = [Prix Total]",
              "VAR PoidsPrecedent =",
              "    CALCULATE(",
              "        [Prix Total],",
              "        DATEADD(DIM_DATE[Mois_Fiscal], -1, MONTH)",
              "    )",
              "RETURN",
              "    DIVIDE(PoidsActuel - PoidsPrecedent, PoidsPrecedent, 0)"
            ],
            "formatString": "0.00 %;-0.00 %;0.00 %"
          },
          {
            "name": "Poids Venduuu Growth P %",
            "expression": [
              "",
              "VAR PoidsActuel = [POIDS TOTAL]",
              "VAR PoidsPrecedent =",
              "    CALCULATE(",
              "        [POIDS TOTAL],",
              "        DATEADD(DIM_DATE[PK_Date],-COUNTROWS(VALUES(DIM_DATE[PK_Date])), DAY)",
              "    )",
              "RETURN DIVIDE(PoidsActuel - PoidsPrecedent, PoidsPrecedent,0)"
            ]
          }
        ],
