                <property
                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
TC.DATE_CHARGEMENT,
TPC.CODE_ARTICLE,
TPC.CODE_SECTEUR,
TPC.TOTAL_CHARGEE,
TPC.PRIX_VNT,
TPC.TOTAL_INVENDU_POINTE,
TPC.TOTAL_RENDUS_COM,
TPC.TOTAL_RENDUS_US
FROM T_CHARGEMENT TC
INNER JOIN T_PRODUITS_CHARGEE TPC ON TPC.CODE_CHARGEMENT = TC.CODE_CHARGEMENT;

SELECT * FROM T_ARTICLES</property>
                <property
                  dataType="System.String"
                  description="Variable contenant la commande SQL à exécuter."
                  name="SqlCommandVariable"></property>
