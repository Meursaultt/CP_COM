                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (select * from [dbo].[DIM_ARTICLE]) [refTable]
where [refTable].[CODE_ARTICLE] = ?</property>
                <property
